---
import { siteMeta, ui } from "../data/site.js";

const { home = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const sectionHref = (id) => (home ? `#${id}` : `${base}#${id}`);
---

<nav class="topbar" aria-label="Primary">
  <div class="brand-cluster">
    <a class="brand" href={base}>{siteMeta.name}</a>
  </div>
  <div class="topbar__links">
    <a href={`${base}blog/`}>{ui.nav.blog}</a>
    <a href={sectionHref("background")}>{ui.nav.background}</a>
    <button
      class="theme-toggle"
      type="button"
      aria-label={ui.nav.switchToLight}
      aria-pressed="false"
      data-theme-label-dark={ui.nav.switchToDark}
      data-theme-label-light={ui.nav.switchToLight}
    >
      <span class="theme-toggle__track" aria-hidden="true">
        <span class="theme-toggle__thumb"></span>
      </span>
      <!-- <span class="theme-toggle__label">White</span> -->
    </button>
  </div>
</nav>

<script>
  const themeToggle = document.querySelector(".theme-toggle");

  const setTheme = (theme) => {
    const isLight = theme === "light";
    const lightLabel = themeToggle?.dataset.themeLabelLight ?? "";
    const darkLabel = themeToggle?.dataset.themeLabelDark ?? "";
    if (isLight) {
      document.documentElement.dataset.theme = "light";
    } else {
      document.documentElement.removeAttribute("data-theme");
    }
    themeToggle?.setAttribute("aria-pressed", String(isLight));
    themeToggle?.setAttribute("aria-label", isLight ? darkLabel : lightLabel);
  };

  const getSavedTheme = () => {
    try {
      return localStorage.getItem("theme") === "light" ? "light" : "dark";
    } catch {
      return "dark";
    }
  };

  setTheme(getSavedTheme());

  themeToggle?.addEventListener("click", () => {
    const nextTheme = document.documentElement.dataset.theme === "light" ? "dark" : "light";
    try {
      if (nextTheme === "light") {
        localStorage.setItem("theme", "light");
      } else {
        localStorage.removeItem("theme");
      }
    } catch {
      // Keep the toggle usable even when persistent storage is unavailable.
    }
    setTheme(nextTheme);
  });
</script>
