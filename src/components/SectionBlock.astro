---
const { id, eyebrow, title, intro, class: className } = Astro.props;
---

<section class:list={["section", className]} id={id}>
  <div class="section__heading">
    {eyebrow && <p class="section__eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {intro && <p class="section__intro">{intro}</p>}
  </div>
  <div class="section__body">
    <slot />
  </div>
</section>
