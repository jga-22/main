---
const { items } = Astro.props;

const icons = {
  linkedin:
    '<path d="M6.94 8.5H3.56V20h3.38zm.22-3.68A1.96 1.96 0 0 0 5.25 2.9a1.96 1.96 0 1 0 0 3.92 1.96 1.96 0 0 0 1.91-2zM20 13.18c0-3.32-1.77-4.87-4.13-4.87a3.58 3.58 0 0 0-3.22 1.77V8.5H9.28c.04 1.03 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.69.12-.93a2.22 2.22 0 0 1 2.08-1.48c1.47 0 2.06 1.12 2.06 2.76V20H20z"/>',
  mail:
    '<path d="M3 5.5h18a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-11a1 1 0 0 1 1-1zm0 1.8v.2l9 5.74 9-5.74v-.2zm18 2.32-8.46 5.38a1 1 0 0 1-1.08 0L3 9.62v7.08h18z"/>',
  phone:
    '<path d="M6.62 3.5h2.76c.44 0 .81.32.88.76l.47 3.11a.9.9 0 0 1-.26.8l-1.7 1.66a14.45 14.45 0 0 0 5.4 5.4l1.66-1.7a.9.9 0 0 1 .8-.26l3.11.47c.44.07.76.44.76.88v2.76a.9.9 0 0 1-.9.9h-1.8C9.95 21.18 2.82 14.05 2.82 5.3V3.5a.9.9 0 0 1 .9-.9z"/>'
};
---

<div class="contact-bar" aria-label="Contact">
  {items.map((item) => (
    <a
      class="contact-bar__link"
      href={item.href}
      target={item.href.startsWith("http") ? "_blank" : undefined}
      rel={item.href.startsWith("http") ? "noreferrer" : undefined}
      aria-label={item.label}
      title={item.label}
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" set:html={icons[item.icon]} />
    </a>
  ))}
</div>
