---
const { items } = Astro.props;
const { compact = false } = Astro.props;

const icons = {
  linkedin:
    '<path d="M6.94 8.5H3.56V20h3.38zm.22-3.68A1.96 1.96 0 0 0 5.25 2.9a1.96 1.96 0 1 0 0 3.92 1.96 1.96 0 0 0 1.91-2zM20 13.18c0-3.32-1.77-4.87-4.13-4.87a3.58 3.58 0 0 0-3.22 1.77V8.5H9.28c.04 1.03 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.69.12-.93a2.22 2.22 0 0 1 2.08-1.48c1.47 0 2.06 1.12 2.06 2.76V20H20z"/>',
  github:
    '<path d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.09 3.3 9.4 7.87 10.93.58.11.79-.25.79-.56v-2.17c-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.26-1.28-5.26-5.71 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.82 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.44-2.71 5.41-5.29 5.69.42.36.79 1.07.79 2.17v3.22c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.66 18.35.5 12 .5z"/>'
};
---

<div class:list={["contact-bar", compact && "contact-bar--compact"]} aria-label="Contact">
  {items.map((item) => (
    <a
      class="contact-bar__link"
      href={item.href}
      target={item.href.startsWith("http") ? "_blank" : undefined}
      rel={item.href.startsWith("http") ? "noreferrer" : undefined}
      aria-label={item.label}
      title={item.label}
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" set:html={icons[item.icon]} />
    </a>
  ))}
</div>
