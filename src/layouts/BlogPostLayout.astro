---
import BaseLayout from "./BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";

const { frontmatter } = Astro.props;
const title = `${frontmatter.title} | Juan Galvis`;
const description = frontmatter.description ?? frontmatter.excerpt ?? "Blog post by Juan Galvis";
---

<BaseLayout title={title} description={description}>
  <main class="page-shell page-shell--article">
    <SiteNav />

    <article class="article">
      <header class="article__header">
        <p class="article__eyebrow">{frontmatter.date}</p>
        <h1 class="article__title">{frontmatter.title}</h1>
        {frontmatter.excerpt && <p class="article__excerpt">{frontmatter.excerpt}</p>}
      </header>

      <div class="article__content">
        <slot />
      </div>
    </article>
    <SiteFooter />
  </main>
</BaseLayout>
