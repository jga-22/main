---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteNav from "../../components/SiteNav.astro";

const base = import.meta.env.BASE_URL;
const categoryLabels = {
  life: "Life",
  technology: "Technology",
  "work-experience": "Work experience"
};

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((post) => ({
    title: post.data.title,
    href: `${base}blog/${post.slug}/`,
    date: post.data.date.toISOString().slice(0, 10),
    category: categoryLabels[post.data.category],
    excerpt: post.data.excerpt
  }));
---

<BaseLayout title="Blog | Juan Galvis" description="Notes and essays by Juan Galvis.">
  <main class="page-shell page-shell--article">
    <SiteNav />

    <section class="section">
      <div class="section__heading">
        <p class="section__eyebrow">Blog</p>
        <h1 class="article__title">Notes, essays, and working thoughts.</h1>
        <p class="section__intro">A space for ideas that sit between work, systems, technology, and life.</p>
      </div>

      <div class="blog-list">
        {posts.map((post) => (
          <a class="card card--link" href={post.href}>
            <span class="card__meta">{post.category} · {post.date}</span>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
    <SiteFooter />
  </main>
</BaseLayout>
