---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import TextIntro from "../components/TextIntro.astro";
import TimelineItem from "../components/TimelineItem.astro";
import {
  personalIntro,
  siteMeta,
  timelineSection,
  timeline
} from "../data/site.js";

---

<BaseLayout title={`${siteMeta.name} | Personal website`} description={siteMeta.description}>
  <main class="page-shell">
    <section class="hero">
      <SiteNav home={true} />

      <div class="hero__grid">
        <div class="hero__title-wrap">
          <h1>{siteMeta.title}</h1>
        </div>

        <!-- <div class="hero__copy">
          <p class="hero__lede">{hero.headline}</p>
          <p class="hero__body">{hero.body}</p>
        </div> -->

      </div>
    </section>

    <TextIntro
      paragraphs={personalIntro.paragraphs}
      body={personalIntro.body}
    />

    <!-- <SectionBlock
      id="focus"
      eyebrow={focusSection.eyebrow}
      title={focusSection.title}
      intro={focusSection.intro}
    >
      <div class="grid grid--three">
        {focusAreas.map((area) => (
          <article class="card">
            <h3>{area.title}</h3>
            <p>{area.text}</p>
          </article>
        ))}
      </div>
    </SectionBlock> -->

    <SectionBlock
      id="background"
      class="section--plain"
      eyebrow={timelineSection.eyebrow}
    >
      <div class="timeline">
        {timeline.map((item) => (
          <TimelineItem {...item} />
        ))}
      </div>
    </SectionBlock>

    <SiteFooter />
  </main>
</BaseLayout>
