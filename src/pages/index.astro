---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactBar from "../components/ContactBar.astro";
import NoteCard from "../components/NoteCard.astro";
import SectionBlock from "../components/SectionBlock.astro";
import TimelineItem from "../components/TimelineItem.astro";
import WorkCard from "../components/WorkCard.astro";
import {
  contactLinks,
  focusAreas,
  intro,
  selectedWork,
  siteMeta,
  timeline,
  writingNotes
} from "../data/site.js";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${siteMeta.name} | Personal website`} description={siteMeta.description}>
  <main class="page-shell">
    <section class="hero">
      <nav class="topbar" aria-label="Primary">
        <a class="brand" href={base}>{siteMeta.name}</a>
        <div class="topbar__links">
          <a href="#focus">Approach</a>
          <a href="#work">Work</a>
          <a href="#notes">Thoughts</a>
          <a href={`${base}blog/`}>Blog</a>
          <a href="#background">Background</a>
          <a href="#connect">Connect</a>
        </div>
      </nav>

      <div class="hero__grid">
        <div class="hero__title-wrap">
          <p class="hero__eyebrow">{intro.eyebrow}</p>
          <h1>{siteMeta.title}</h1>
        </div>

        <div class="hero__copy">
          <p class="hero__lede">{intro.headline}</p>
          <p class="hero__body">{intro.body}</p>

          <div class="hero__actions">
            <a class="button button--primary" href="#work">Selected work</a>
            <a class="button button--ghost" href={`${base}blog/`}>Blog</a>
          </div>
        </div>

        <aside class="hero__panel">
          <p class="hero__panel-title">Contact</p>
          <ContactBar items={contactLinks} />
        </aside>
      </div>
    </section>

    <SectionBlock
      id="focus"
      eyebrow="Approach"
      title="I work on systems that need clarity, structure, and operational usefulness."
      intro="The common thread across my work is simple: build things that can survive complexity without becoming vague, fragile, or theatrical."
    >
      <div class="grid grid--three">
        {focusAreas.map((area) => (
          <article class="card">
            <h3>{area.title}</h3>
            <p>{area.text}</p>
          </article>
        ))}
      </div>
    </SectionBlock>

    <SectionBlock
      id="work"
      eyebrow="Selected work"
      title="A few work streams that describe the problems I spend time on."
      intro="This is a compact view of the environments, products, and decisions that shape my current practice."
    >
      <div class="grid grid--three">
        {selectedWork.map((item) => (
          <WorkCard {...item} />
        ))}
      </div>
    </SectionBlock>

    <SectionBlock
      id="notes"
      eyebrow="Thoughts"
      title="Ideas I want to make explicit."
      intro="Writing is part of the site on purpose. It is where product decisions, technical context, and broader patterns can be made visible."
    >
      <div class="grid grid--three">
        {writingNotes.map((note) => (
          <NoteCard {...note} />
        ))}
      </div>
    </SectionBlock>

    <SectionBlock
      id="background"
      eyebrow="Background"
      title="The background behind the current point of view."
      intro="A short timeline is enough to show where the work comes from without turning the whole site into a resume."
    >
      <div class="timeline">
        {timeline.map((item) => (
          <TimelineItem {...item} />
        ))}
      </div>
    </SectionBlock>

    <SectionBlock
      id="connect"
      eyebrow="Connect"
      title="Useful paths to reach me and follow the work."
      intro="A minimal contact bar for direct access."
    >
      <ContactBar items={contactLinks} />
    </SectionBlock>

    <footer class="footer">
      <p>{siteMeta.name} - AI product, systems thinking, and selected work.</p>
    </footer>
  </main>
</BaseLayout>
