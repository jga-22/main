---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import TextIntro from "../components/TextIntro.astro";
import TimelineItem from "../components/TimelineItem.astro";
import {
  personalIntro,
  siteMeta,
  timelineSection,
  timeline
} from "../data/site.js";
const base = import.meta.env.BASE_URL;
const ogImageUrl = new URL(`${base}${siteMeta.ogImage.replace(/^\//, "")}`, Astro.site).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteMeta.name,
  description: siteMeta.description,
  image: ogImageUrl,
  url: Astro.site?.toString(),
  sameAs: [siteMeta.linkedin, siteMeta.github]
};

---

<BaseLayout
  title={`${siteMeta.name} | ${siteMeta.role}`}
  description={siteMeta.description}
  canonicalPath={Astro.url.pathname}
  jsonLd={jsonLd}
>
  <main class="page-shell">
    <SiteNav home={true} />

    <section class="hero">
      <div class="hero__grid">
        <div class="hero__title-wrap">
          <h1>Hello <span class="text-accent">!</span></h1>
        </div>

      </div>
    </section>

    <TextIntro
      paragraphs={personalIntro.paragraphs}
      body={personalIntro.body}
    />


    <SectionBlock
      id="background"
      class="section--plain"
      eyebrow={timelineSection.eyebrow}
    >
      <div class="timeline">
        {timeline.map((item) => (
          <TimelineItem {...item} />
        ))}
      </div>
    </SectionBlock>

    <SiteFooter />
  </main>
</BaseLayout>
